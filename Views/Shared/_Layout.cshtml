<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hotelaria Luxury</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="container">
                <a class="navbar-brand" href="~/">
                    <span>🏨</span>
                    <span>Hotelaria <span class="gold-text">Luxury</span></span>
                </a>
                <ul class="nav-links">
                    <li><a href="~/">Início</a></li>
                    <li><a href="~/Home/Pacotes">Pacotes</a></li>
                    <li><a href="~/Reservas">Reservas</a></li>
                    <li><a href="~/Reservas/Criar" class="btn-nav">Nova Reserva</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main class="container">
        @if (TempData["Sucesso"] != null)
        {
            <div class="alert alert-success">
                <span>✓</span>
                <span>@TempData["Sucesso"]</span>
            </div>
        }
        @if (TempData["Erro"] != null)
        {
            <div class="alert alert-danger">
                <span>✗</span>
                <span>@TempData["Erro"]</span>
            </div>
        }
        
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2025 Hotelaria Luxury - Sistema de Hotelaria com Padrões Builder + Prototype</p>
        </div>
    </footer>
</body>
</html>
